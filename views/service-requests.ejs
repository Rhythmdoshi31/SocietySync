<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Service Request</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              sos: "#E53935",
              appBg: "#F8F9FA",
              cardBg: "#FFFFFF", 
              appBlue: "#4A90E2",
              appText: "#333333",
              appGray: "#757575"
            }
          }
        }
      }
    </script>
</head>
<body class="bg-appBg min-h-screen flex flex-col items-center p-4">

    <div class="fixed top-0 left-0 right-0 bg-white shadow-sm z-10">
        <div class="max-w-md mx-auto px-4 h-16 flex items-center justify-between">
          <a href="/" class="p-2 rounded-full hover:bg-gray-100">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="3" y1="12" x2="21" y2="12"></line>
              <line x1="3" y1="6" x2="21" y2="6"></line>
              <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
          </a>
          
          <h1 class="text-lg font-semibold">SocietySync</h1>
          
          <button class="bg-sos text-white rounded-full w-10 h-10 flex items-center justify-center animate-pulse-sos shadow-md">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
              <line x1="12" y1="9" x2="12" y2="13"></line>
              <line x1="12" y1="17" x2="12.01" y2="17"></line>
            </svg>
          </button>
        </div>
    </div>

    <div class="max-w-md w-full bg-white p-6 rounded-lg shadow-md mt-20">
        <h2 class="text-lg font-semibold text-appText mb-4">Request a Service</h2>
        <form action="/service-requests" method="POST" enctype="multipart/form-data" class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-appText">Service Required</label>
                <select name="service" class="mt-1 block w-full p-2 border rounded-lg">
                    <option value="plumbing">Plumbing</option>
                    <option value="electrical">Electrical</option>
                    <option value="cleaning">Cleaning</option>
                    <option value="carpentry">Carpentry</option>
                    <option value="masonry">Masonry</option>
                    <option value="other">Other</option>
                </select>
            </div>
            
            <div>
                <label class="block text-sm font-medium text-appText">Upload Image (Optional)</label>
                <input type="file" name="image" class="mt-1 block w-full p-2 border rounded-lg">
            </div>
            
            <div>
                <label class="block text-sm font-medium text-appText">Service Description</label>
                <textarea name="description" rows="3" class="mt-1 block w-full p-2 border rounded-lg" placeholder="Describe your service requirement..."></textarea>
            </div>
            
            <button type="submit" class="w-full bg-appBlue text-white py-2 rounded-lg hover:bg-blue-700">Submit Request</button>
        </form>

        <!-- New "View My Requests" Button -->
        <a href="/service-requests/my-requests" class="w-full mt-4 inline-block text-center bg-gray-300 text-black py-2 rounded-lg hover:bg-gray-400">
            View My Requests
        </a>
    </div>
    <!-- Footer Bar -->
    <div class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 z-10">
      <div class="max-w-md mx-auto flex justify-between">
        <button class="flex flex-col items-center justify-center py-2 px-4 text-appBlue">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
            <polyline points="9 22 9 12 15 12 15 22"></polyline>
          </svg>
          <span class="text-xs mt-1">Home</span>
        </button>
        
        <button class="flex flex-col items-center justify-center py-2 px-4 text-appGray">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
            <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
          </svg>
          <span class="text-xs mt-1">Alerts</span>
        </button>
        
        <button class="flex flex-col items-center justify-center py-2 px-4 text-appGray">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"></polygon>
            <line x1="8" y1="2" x2="8" y2="18"></line>
            <line x1="16" y1="6" x2="16" y2="22"></line>
          </svg>
          <span class="text-xs mt-1">Map</span>
        </button>
        
        <button class="flex flex-col items-center justify-center py-2 px-4 text-appGray">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
            <circle cx="12" cy="7" r="4"></circle>
          </svg>
          <span class="text-xs mt-1">Profile</span>
        </button>
        
        <button class="flex flex-col items-center justify-center py-2 px-4 text-appGray">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3"></circle>
            <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
          </svg>
          <span class="text-xs mt-1">Settings</span>
        </button>
      </div>
    </div>
    
</body>
</html>
