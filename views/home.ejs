<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>SocietySync</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            sos: "#E53935",
            appBg: "#F8F9FA",
            cardBg: "#FFFFFF", 
            appBlue: "#4A90E2",
            appText: "#333333",
            appGray: "#757575"
          },
          animation: {
            'pulse-sos': 'pulse-sos 2s infinite'
          },
          keyframes: {
            'pulse-sos': {
              '0%, 100%': { opacity: '1', transform: 'scale(1)' },
              '50%': { opacity: '0.9', transform: 'scale(1.05)' }
            }
          }
        }
      }
    }
  </script>
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      -webkit-tap-highlight-color: transparent;
    }
  </style>
</head>
<body class="bg-appBg text-appText">
  <div class="max-w-md mx-auto min-h-screen flex flex-col">
    
    <!-- Navigation Bar -->
    <div class="fixed top-0 left-0 right-0 bg-white shadow-sm z-10">
      <div class="max-w-md mx-auto px-4 h-16 flex items-center justify-between">
        <a href="/" class="p-2 rounded-full hover:bg-gray-100">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
        </a>
        


        <h1 class="text-lg font-semibold">SocietySync</h1>
        
        <button 
  class="bg-sos text-white rounded-full w-10 h-10 flex items-center justify-center animate-pulse-sos shadow-md"
  onclick="window.open('/sos', '_self')"
>
  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
    <line x1="12" y1="9" x2="12" y2="13"></line>
    <line x1="12" y1="17" x2="12.01" y2="17"></line>
  </svg>
</button>


      </div>
    </div>
    
    <!-- Page Content -->
    <div class="flex-1 p-4 pb-24 pt-20">
      
      <!-- Notification Panel -->
      <a href="/events">
        <div class="bg-white rounded-lg shadow-lg p-4 mb-6">
            <div class="p-4 bg-white rounded-lg shadow-lg border border-gray-200">
                <h3 class="text-md font-semibold text-appText">Holi Celebration</h3>
                <p class="text-blue-500 text-sm"><strong>Date:</strong> 22/03/2025</p>
                <p class="text-blue-500 text-sm"><strong>Location:</strong> Football Ground</p>
            </div>
        </div>
    </a>
    
      
      <!-- Grid Items -->
      <div class="grid grid-cols-3 gap-4">
        <% 
          const items = [
            { icon: 'shopping-cart', title: 'Shop & Groceries', route: '/shop' }, 
            { icon: 'wrench', title: 'Services', route: '/service-requests' }, 
            { icon: 'calendar', title: 'Upcoming Events', route: '/events' }, 
            { icon: 'user', title: 'My Profile', route: '/auth/profile' }, 
            { icon: 'shield-alert', title: 'Theft Reporting', route: '/theft-report' }, 
            { icon: 'dollar-sign', title: 'Rent & Maintenance', route: '/rent' }
          ];
        
          items.forEach(item => { %>
            <div class="bg-white p-4 rounded-lg shadow-lg flex flex-col items-center justify-center gap-2 transition-transform active:scale-95 cursor-pointer" data-route="<%= item.route %>">
              <div class="bg-appBlue bg-opacity-10 rounded-full p-3 mb-2">
                <% if (item.icon === 'shopping-cart') { %>
                  <svg width="24" height="24" fill="none" stroke="#4A90E2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="9" cy="21" r="1"></circle>
                    <circle cx="20" cy="21" r="1"></circle>
                    <path d="M1 1h4l2 13h13l3-7H6"></path>
                  </svg>
                <% } else if (item.icon === 'wrench') { %>
                  <svg width="24" height="24" fill="none" stroke="#4A90E2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14.7 14.7a6 6 0 1 1-4.4-4.4L2 3v6h6"></path>
                    <path d="M22 22l-5.5-5.5"></path>
                  </svg>
                <% } else if (item.icon === 'calendar') { %>
                  <svg width="24" height="24" fill="none" stroke="#4A90E2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="4" width="18" height="18" rx="2"></rect>
                    <line x1="16" y1="2" x2="16" y2="6"></line>
                    <line x1="8" y1="2" x2="8" y2="6"></line>
                    <line x1="3" y1="10" x2="21" y2="10"></line>
                  </svg>
                <% } else if (item.icon === 'user') { %>
                  <svg width="24" height="24" fill="none" stroke="#4A90E2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="7" r="4"></circle>
                    <path d="M5 21v-2a4 4 0 0 1 4-4h6a4 4 0 0 1 4 4v2"></path>
                  </svg>
                <% } else if (item.icon === 'shield-alert') { %>
                  <svg width="24" height="24" fill="none" stroke="#4A90E2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 2l9 4-9 4-9-4z"></path>
                    <path d="M12 22V10"></path>
                  </svg>
                <% } else if (item.icon === 'dollar-sign') { %>
                  <svg width="24" height="24" fill="none" stroke="#4A90E2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="12" y1="1" x2="12" y2="23"></line>
                    <path d="M17 5H9.5a4.5 4.5 0 0 0 0 9H14.5a4.5 4.5 0 0 1 0 9H7"></path>
                  </svg>
                <% } %>
              </div>
              <h3 class="font-medium text-center"><%= item.title %></h3>
            </div>
          <% }); %>
      </div>
      <!-- Footer Bar -->
      <div class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 z-10">
        <div class="max-w-md mx-auto flex justify-between">
          <button class="flex flex-col items-center justify-center py-2 px-4 text-appBlue">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
              <polyline points="9 22 9 12 15 12 15 22"></polyline>
            </svg>
            <span class="text-xs mt-1">Home</span>
          </button>
          
          <button class="flex flex-col items-center justify-center py-2 px-4 text-appGray">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
              <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
            </svg>
            <span class="text-xs mt-1">Alerts</span>
          </button>
          
          <button class="flex flex-col items-center justify-center py-2 px-4 text-appGray">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"></polygon>
              <line x1="8" y1="2" x2="8" y2="18"></line>
              <line x1="16" y1="6" x2="16" y2="22"></line>
            </svg>
            <span class="text-xs mt-1">Services</span>
          </button>
          
          <button class="flex flex-col items-center justify-center py-2 px-4 text-appGray">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
            <span class="text-xs mt-1">Profile</span>
          </button>
          
          <button class="flex flex-col items-center justify-center py-2 px-4 text-appGray">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="3"></circle>
              <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
            </svg>
            <span class="text-xs mt-1">Settings</span>
          </button>
        </div>
      </div>
    </div>
  </div>

  <script>
    document.querySelectorAll('.grid-cols-3 > div').forEach(item => {
      item.addEventListener('click', function() {
        window.location.href = this.getAttribute("data-route");
      });
    });
  </script>
</body>
</html>
