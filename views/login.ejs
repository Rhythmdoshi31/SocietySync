<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SocietySync</title>
    <link rel="icon" type="image/png" href="/fav.png">
    <script src="https://unpkg.com/tailwindcss-cdn@3.4.10/tailwindcss.js"></script>
</head>
<body>
    <div class="h-screen w-screen bg-zinc-100 flex items-center justify-center">
        <% if (error) { %>
            <div class="flex flex-col justify-center items-center">
                <h1 class="text-red-600 font-semibold text-lg"><%= error %></h1>
                <a class="text-sky-500 font-semibold text-xl" href="/auth/login">Click here to Try Again</a>
            </div>
        <% } else { %>
            <div class="w-[70vw] md:w-[50vw] lg:w-[35vw] flex flex-col items-center">
                <h1 class="text-3xl font-bold text-blue-700 mb-3 text-center">SocietySync - Smarter, Safer and Secure Society</h1>
                <h1 class="text-2xl font-semibold mb-3">Log In Your Account</h1>
                <form action="/auth/login" method="POST" class="flex flex-col items-start gap-3">
                    <input class="p-3 bg-zinc-200 rounded-lg w-[100%]" type="email" name="email" placeholder="Enter your email" required>
                    <input class="p-3 bg-zinc-200 rounded-lg w-[100%]" type="password" name="password" placeholder="Enter your password" required>
                    <div>
                        <input class="py-2 px-6 text-xl text-white bg-sky-500 hover:bg-sky-600 duration-300 rounded-lg" type="submit" value="Log In">
                        <a class="ml-1 underline" href="/auth/register">Or SignUp here.</a>
                    </div>
                </form>
            </div>
        <% } %>
    </div>
</body>
</html>
